{
    "extends": "@total-typescript/tsconfig/tsc/dom/library",
    "compilerOptions": {
        "sourceMap": false,
        "target": "ESNext",
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "paths": {
            "sharp": ["./node_modules/sharp/lib/index.d.ts"]
        },
        "noEmit": true,
        "allowImportingTsExtensions": true,
        "allowJs": false,
        "isolatedDeclarations": true
    },
    "include": ["src", "scripts"],
    "exclude": ["src/items.ts", "src/translations"]
}
