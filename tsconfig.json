{
    "extends": "@total-typescript/tsconfig/tsc/dom/library",
    "compilerOptions": {
        "sourceMap": false,
        "target": "ESNext",
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "noEmit": true,
        "allowImportingTsExtensions": true,
        "allowJs": false,
        "isolatedDeclarations": true,
        "types": ["node"]
    },
    "include": ["src", "scripts"],
    "exclude": ["src/items.ts", "src/translations"]
}
