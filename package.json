{
    "name": "@ianlucas/cs2-lib",
    "description": "A TypeScript library for manipulating Counter-Strike 2 data",
    "license": "MIT",
    "author": "Ian Lucas",
    "keywords": [
        "cs2",
        "counter-strike",
        "counter-strike-2",
        "csgo",
        "cs-go"
    ],
    "homepage": "https://github.com/ianlucas/cs2-lib#readme",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/ianlucas/cs2-lib.git"
    },
    "bugs": {
        "url": "https://github.com/ianlucas/cs2-lib/issues"
    },
    "type": "module",
    "main": "./dist/index.mjs",
    "types": "./dist/index.d.mts",
    "exports": {
        ".": {
            "types": "./dist/index.d.mts",
            "import": "./dist/index.mjs"
        },
        "./translations": {
            "types": "./dist/translations/index.d.mts",
            "import": "./dist/translations/index.mjs"
        },
        "./translations/*": {
            "types": "./dist/translations/*.d.mts",
            "import": "./dist/translations/*.mjs"
        }
    },
    "sideEffects": false,
    "files": [
        "dist"
    ],
    "scripts": {
        "docs": "typedoc",
        "format": "prettier . --write",
        "prepack": "rolldown -c rolldown.config.ts",
        "test": "vitest --run --testTimeout 120000",
        "typecheck": "tsc --noEmit",
        "update": "npm run item-generator && npm run item-generator-changelog",
        "upgrade": "npx npm-check-updates@latest --target minor -u",
        "item-generator-changelog": "tsx scripts/item-generator-changelog.ts",
        "item-generator": "dotnet run --project scripts/item-generator"
    },
    "devDependencies": {
        "@gltf-transform/core": "^4.4.0",
        "@gltf-transform/extensions": "^4.4.0",
        "@total-typescript/tsconfig": "^1.0.4",
        "@types/node": "^22.20.0",
        "javascript-stringify": "^2.1.0",
        "meshoptimizer": "^1.2.0",
        "prettier": "3.9.4",
        "rolldown": "^1.1.3",
        "rolldown-plugin-dts": "^0.26.0",
        "rollup-plugin-delete": "^3.0.2",
        "sharp": "0.35.2",
        "tsx": "^4.22.4",
        "typedoc": "^0.28.19",
        "typescript": "^6.0.3",
        "vitest": "^4.1.9"
    },
    "engines": {
        "node": ">=20"
    }
}
